{
  "name": "ecofund-icp-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm i && dfx canister create ecofund-icp-backend && dfx generate ecofund-icp-backend && dfx deploy",
    "start": "vite --port 3000",
    "prebuild": "dfx generate",
    "build": "tsc && vite build",
    "format": "prettier --write \"src/**/*.{json,js,jsx,ts,tsx,css,scss}\"",
    "prepare": "npm run smui-theme-light && npm run smui-theme-dark",
    "smui-theme-light": "smui-theme compile static/smui.css -i src/theme",
    "smui-theme-dark": "smui-theme compile static/smui-dark.css -i src/theme/dark"
  },
  "dependencies": {
    "@dfinity/agent": "^0.20.0",
    "@dfinity/candid": "^0.20.0",
    "@dfinity/principal": "^0.20.0"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@smui/button": "^7.0.0",
    "@smui/card": "^7.0.0",
    "@smui/top-app-bar": "^7.0.0",
    "@sveltejs/adapter-static": "^2.0.0",
    "@sveltejs/kit": "^1.21.0",
    "@sveltejs/vite-plugin-svelte": "^2.4.2",
    "dotenv": "^16.3.1",
    "sass": "^1.63.6",
    "smui-theme": "^7.0.0",
    "svelte": "^4.0.1",
    "svelte-check": "^3.4.4",
    "typescript": "^5.1.3",
    "vite": "^4.3.9",
    "vite-plugin-environment": "^1.1.3"
  }
}
